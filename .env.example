# CAIPE UI Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Feature Flags
# ============================================
# Enable SSO authentication (set to false for development without SSO)
NEXT_PUBLIC_SSO_ENABLED=true

# Grant anonymous users admin role when SSO is disabled (default: false)
# Only relevant for local development without SSO
# ALLOW_ANONYMOUS_ADMIN=true

# Enable sub-agent cards in chat interface
NEXT_PUBLIC_ENABLE_SUBAGENT_CARDS=true

# Enable admin audit logs — allows full admins to browse all conversations (disabled by default)
# AUDIT_LOGS_ENABLED=true

# Enable server-side user identity via JWT.
# When true, the UI stops prefixing messages with "by user: email" — the server
# extracts user info from the JWT token directly.
# Same env var name as the backend — set once in docker-compose for both services.
ENABLE_USER_INFO_TOOL=false

# ============================================
# NextAuth Configuration
# ============================================
# Secret for JWT encryption - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Separate signing key for skills API tokens (optional)
# Falls back to NEXTAUTH_SECRET if not set
# SKILLS_API_SECRET=your-skills-secret-here

# Base URL of your application
NEXTAUTH_URL=http://localhost:3000

# ============================================
# OIDC/SSO Configuration
# ============================================
# OIDC Provider Issuer URL (e.g., https://your-idp.com/oidc)
OIDC_ISSUER=https://your-oidc-provider.com

# OIDC Client ID
OIDC_CLIENT_ID=your-client-id

# OIDC Client Secret
OIDC_CLIENT_SECRET=your-client-secret

# Required group for authorization (optional, default: backstage-access)
# Leave empty or comment out to allow all authenticated users
# OIDC_REQUIRED_GROUP=backstage-access

# Custom OIDC group claim name (optional)
# If not set, will auto-detect from: memberOf, groups, group, roles, cognito:groups
# OIDC_GROUP_CLAIM=groups

# ============================================
# Token Refresh Configuration
# ============================================
# Enable automatic token refresh using OIDC refresh tokens (default: true)
# Set to "false" if your OIDC provider doesn't support offline_access scope
# When disabled, users will see expiry warnings but won't auto-refresh
# OIDC_ENABLE_REFRESH_TOKEN=true

# ============================================
# Storage Configuration (Optional)
# ============================================
# MongoDB connection string for use case storage (optional)
# If not set, uses file-based storage
# MONGODB_URI=mongodb://localhost:27017/caipe

# MongoDB database name (optional, default: caipe)
# MONGODB_DB=caipe

# ============================================
# UI Customization
# ============================================
# Application name displayed throughout the UI (default: CAIPE)
# NEXT_PUBLIC_APP_NAME=My Platform

# Custom favicon URL for browser tab (default: /favicon.ico)
# NEXT_PUBLIC_FAVICON_URL=https://example.com/my-favicon.png

# Enabled integration icons on login page orbit (comma-separated)
# If not set, all icons are shown (backwards compatible)
# Available icons: argocd, aws, github, gitlab, jira, splunk, confluence, webex, kubernetes, slack, backstage, command line, workflows, pagerduty, linux
# NEXT_PUBLIC_ENABLED_INTEGRATION_ICONS=github,gitlab,slack,aws,kubernetes

# ============================================
# UI Personalization Defaults
# ============================================
# These set the initial defaults for new users who haven't customized their preferences.
# Users can still override these in the UI Personalization panel.

# Default font size: small (14px), medium (16px), large (18px), x-large (20px)
# DEFAULT_FONT_SIZE=medium

# Default font family: inter, source-sans, ibm-plex, system
# DEFAULT_FONT_FAMILY=inter

# Default color theme: light, dark, midnight, nord, tokyo
# DEFAULT_THEME=dark

# Default gradient theme: default, minimal, professional, ocean, sunset
# DEFAULT_GRADIENT_THEME=default

# Gradient colors (CSS color values, used by the "default" gradient theme)
# GRADIENT_FROM=hsl(173,80%,40%)
# GRADIENT_TO=hsl(270,75%,60%)

# Loading spinner color (CSS color value)
# SPINNER_COLOR=

# ============================================
# Bootstrap Admin (solves chicken-and-egg problem)
# ============================================
# Comma-separated emails granted admin on login, before any OIDC group
# or Keycloak role mapping exists.  Once the first admin has configured
# proper group mappings via the Roles tab, remove this variable.
# BOOTSTRAP_ADMIN_EMAILS=admin@example.com,lead@example.com

# Unsafe dev/emergency escape hatch. When true, UI RBAC checks allow all
# requests without consulting OpenFGA. Never enable this in staging or prod.
# CAIPE_UNSAFE_RBAC_BYPASS=false

# ============================================
# 098 Enterprise RBAC — Keycloak Admin API (US6)
# ============================================
# Service account for managing roles and IdP mappers from the Admin UI.
# For dev: leave KEYCLOAK_ADMIN_CLIENT_SECRET empty to use password grant (admin/admin).
# For production: create a dedicated client with realm-management roles.
# KEYCLOAK_URL=http://localhost:7080
# KEYCLOAK_REALM=caipe
# KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
# KEYCLOAK_ADMIN_CLIENT_SECRET=

# Report a Problem & Ticket Integration
# ============================================
# Show "Report a Problem" button in header and feedback dialog (default: true)
# REPORT_PROBLEM_ENABLED=true

# Jira ticket creation — set both to enable
# JIRA_TICKET_ENABLED=true
# JIRA_TICKET_PROJECT=OPENSD
# JIRA_TICKET_LABEL=caipe-reported

# GitHub issue creation — set both to enable
# GITHUB_TICKET_ENABLED=true
# GITHUB_TICKET_REPO=org/repo
# GITHUB_TICKET_LABEL=caipe-reported

# Skills middleware — FastAPI backend URL for skill scanning (FR-027).
# Required for the skill scanner to run on agent-skills save/publish.
# Without this, scan_status defaults to "unscanned".
# BACKEND_SKILLS_URL=http://localhost:8000
