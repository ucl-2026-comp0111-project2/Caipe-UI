# CAIPE UI Environment Configuration
# Copy this file to .env.local and configure as needed

# ===========================================
# CAIPE Backend Configuration
# ===========================================

# RAG Server URL for knowledge base operations
# For local development: http://localhost:9446
# For Docker: http://rag-server:9446
NEXT_PUBLIC_RAG_URL=http://localhost:9446

# ===========================================
# SSO / OIDC Configuration (Optional)
# ===========================================

# Enable SSO authentication
# Set to "true" to enable OIDC authentication, otherwise leave empty or "false"
NEXT_PUBLIC_SSO_ENABLED=false

# NextAuth.js Configuration
# Generate a real secret with: openssl rand -base64 48
# R4: leave this placeholder ONLY for local dev — the BFF refuses to
# start with a known placeholder (incl. this exact one) when
# NODE_ENV=production. See docs/docs/security/rbac/secrets-bootstrap.md
# section "R4: NEXTAUTH_SECRET strict mode".
NEXTAUTH_SECRET=your-secret-here

# Base URL for NextAuth callbacks
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# Unsafe dev/emergency escape hatch. When true, UI RBAC checks allow all
# requests without consulting OpenFGA. Never enable this in staging or prod.
CAIPE_UNSAFE_RBAC_BYPASS=false

# OIDC Provider Configuration
# These are server-side only (not exposed to browser)
OIDC_ISSUER=https://your-oidc-provider.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Comma-separated list of accepted JWT audience values (in addition to OIDC_CLIENT_ID)
# Useful when the OIDC authorization server mints tokens with a different audience than the client ID
# OIDC_ACCEPTED_AUDIENCES=https://my-api.example.com,urn:my-resource

# ===========================================
# Authorization / Group-Based Access Control
# ===========================================

# OIDC claim name(s) containing user groups
# Supports single value or comma-separated list:
#   Single: memberOf
#   Multiple: groups,members,roles (all checked, results combined and deduplicated)
# Common values: memberOf, groups, members, group, roles, cognito:groups
# Leave empty to auto-detect from common claim names
OIDC_GROUP_CLAIM=memberOf

# Required group for basic Web UI access (checked against the group claim).
# Users must be a member of this deployment-specific group to access the application.
# Leave empty to disable group-based authorization
OIDC_REQUIRED_GROUP=

# Deprecated: admin access is granted through Identity Group Sync + OpenFGA.
OIDC_REQUIRED_ADMIN_GROUP=

# Bootstrap admin emails — comma-separated list for initial admin setup.
# Solves the chicken-and-egg problem: these emails get admin on login.
# Remove after configuring Identity Group Sync to grant OpenFGA admin.
# BOOTSTRAP_ADMIN_EMAILS=admin@example.com,lead@example.com

# Identity Group Sync hybrid mode:
# - login claim reconciliation updates the signed-in user's managed team sources
#   from memberOf/groups claims without storing the full group list in the session.
# - Okta connector settings are server-side only and used by admin dry-runs for
#   full group inventory, removals, drift, and non-logging-in users.
# IDENTITY_SYNC_LOGIN_CLAIMS_ENABLED=true
# IDENTITY_SYNC_OIDC_CLAIM_PROVIDER_ID=oidc-claims
# Background Okta sync — set ORG_URL plus credentials in ONE auth mode to enable
# the Identity Sync tab (Admin > Teams & Users) for scheduling + manual trigger.
# IDENTITY_SYNC_OKTA_ORG_URL=https://your-org.okta.com
#
# Auth mode A — SSWS API token:
# IDENTITY_SYNC_OKTA_API_TOKEN=
#
# Auth mode B — OAuth 2.0 service app (private-key JWT), least privilege.
# Grant scopes okta.groups.read and okta.users.read. Takes precedence over the
# API token when set. PRIVATE_KEY accepts EITHER format Okta exports:
#   • PEM (PKCS#8): -----BEGIN PRIVATE KEY-----...  (escaped \n is tolerated)
#   • JWK (JSON):   {"kty":"RSA","kid":"...","d":"...",...}
# KEY_ID (kid) is optional; for JWK keys it defaults to the JWK's own "kid".
# IDENTITY_SYNC_OKTA_OAUTH_CLIENT_ID=
# IDENTITY_SYNC_OKTA_OAUTH_KEY_ID=
# IDENTITY_SYNC_OKTA_OAUTH_PRIVATE_KEY=

# Support contact email for access requests and help
# Displayed on unauthorized page and error screens
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# ===========================================
# OIDC Callback URLs to Configure
# ===========================================
#
# When setting up your OIDC provider, add these callback URLs:
#
# For localhost development:
#   http://localhost:3000/api/auth/callback/oidc
#
# For production:
#   https://your-domain.com/api/auth/callback/oidc
#
# ===========================================
# Storage Configuration - MongoDB vs localStorage (EXCLUSIVE)
# ===========================================
#
# IMPORTANT: The app uses ONLY ONE storage mode (not hybrid)
# - MongoDB mode: Persistent, shareable, team collaboration
# - localStorage mode: Browser-only, not shareable
#
# Set MONGODB_URI to enable MongoDB mode
# Leave unset for localStorage mode
# CAIPE UI supports TWO storage modes with automatic fallback:
#
# 1. MongoDB Mode (Recommended for Production)
#    - Persistent storage across devices
#    - Sharing and collaboration features
#    - Server-side search
#    - Set MONGODB_URI and MONGODB_DATABASE below
#
# 2. localStorage Mode (Fallback)
#    - Local browser storage only
#    - No setup required
#    - Great for development and demos
#    - Automatically used if MongoDB not configured
#
# The app automatically detects which mode to use and gracefully
# falls back to localStorage if MongoDB is unavailable.
#

# MongoDB connection string (optional - enables MongoDB mode)
# If not set, app runs in localStorage-only mode
# Example: mongodb://localhost:27017
# Example with auth: mongodb://username:password@localhost:27017?authSource=admin
MONGODB_URI=mongodb://admin:changeme@localhost:27017

# MongoDB database name (required if MONGODB_URI is set)
MONGODB_DATABASE=caipe

# Client-side flag to enable MongoDB mode (required!)
# Set to "true" when MONGODB_URI is configured
# This allows client-side code to detect MongoDB mode without exposing the URI
NEXT_PUBLIC_MONGODB_ENABLED=true

# ===========================================
# Connections & Secrets Credential Store (Optional)
# ===========================================
#
# Disabled by default. When enabled, raw credential material is stored only through
# MongoDB envelope encryption and retrieved only by approved server-side callers.
# Browsers may submit values for create/rotate flows but must never retrieve
# decrypted credential material.
CAIPE_CREDENTIALS_ENABLED=false
CREDENTIAL_STORE_BACKEND=mongodb-envelope

# Local testing can use the local-cmk provider with a non-secret CMK alias/ID.
# Production must use aws-kms with a real KMS CMK and narrowly scoped wrap/unwrap
# permissions; local-cmk fails closed in production.
CREDENTIAL_KEY_PROVIDER=local-cmk
CREDENTIAL_KMS_CMK_ID=alias/caipe-local-credentials
CREDENTIAL_KMS_REGION=
CREDENTIAL_ALLOW_LOCALHOST_OAUTH_REDIRECTS=false
CREDENTIAL_SERVICE_AUDIENCE=caipe-credential-service

# Optional startup bootstrap for global OAuth connectors. Docker Compose reads
# these from .env. Kubernetes should source the same env names from ESO.
CREDENTIAL_BOOTSTRAP_OAUTH_CONNECTORS=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/credentials/oauth/github/callback
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_REDIRECT_URI=http://localhost:3000/api/credentials/oauth/atlassian/callback
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=http://localhost:3000/api/credentials/oauth/webex/callback
PAGERDUTY_CLIENT_ID=
PAGERDUTY_CLIENT_SECRET=
PAGERDUTY_REDIRECT_URI=http://localhost:3000/api/credentials/oauth/pagerduty/callback
PAGERDUTY_SCOPES=users.read incidents.read services.read oncalls.read schedules.read teams.read escalation_policies.read
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:3000/api/credentials/oauth/gitlab/callback
GITLAB_SCOPES=api read_user

# ===========================================
# Use Case Storage Configuration
# ===========================================
#
# Storage type for use cases (default: "file")
# Options: "file" or "mongodb"
USECASE_STORAGE_TYPE=file

# File-based storage path (only used when USECASE_STORAGE_TYPE=file)
# Default: ./data/usecases.json
# USECASE_STORAGE_PATH=./data/usecases.json

# ===========================================
# Branding / Customization (Optional)
# ===========================================
#
# Customize the tagline and description shown throughout the UI.
# These appear on login, logout, loading screens, and chat welcome.
#

# Main tagline (default: "Multi-Agent Collaboration & Workflow Automation")
NEXT_PUBLIC_TAGLINE=Multi-Agent Collaboration & Workflow Automation

# Description text (default: "AI agents and native apps collaborating across tools and teams to get work done.")
NEXT_PUBLIC_DESCRIPTION=AI agents and native apps collaborating across tools and teams to get work done.

# Application name (default: "CAIPE")
NEXT_PUBLIC_APP_NAME=CAIPE

# Logo URL (default: "/logo.svg")
# Can be a relative path (e.g., "/custom-logo.svg") or absolute URL (e.g., "https://example.com/logo.png")
NEXT_PUBLIC_LOGO_URL=/logo.svg

# Environment badge (default: empty = hidden)
# Set to a label like "Dev", "Preview", "Staging", or "Prod" to show a badge next to the app name.
# Leave empty or unset to hide the badge entirely.
# Backward-compat: NEXT_PUBLIC_PREVIEW_MODE=true still works (shows "Preview").
NEXT_PUBLIC_ENV_BADGE=

# Workflow runner (default: false)
# Enable the dedicated "Run Workflow" button in the Skills modal and the
# Multi-Step Workflows card section.  When false, users can only "Run in Chat".
WORKFLOW_RUNNER_ENABLED=false

# ===========================================
# Built-in Skill Mutation Lock
# ===========================================
# When false (default), `agent_skills` rows with `is_system: true`
# (seeded built-in templates) are READ-ONLY for all users:
#   - PUT /api/skills/configs?id=<built-in-id>          → 403
#   - DELETE /api/skills/configs?id=<built-in-id>       → 403
#   - PUT /api/skills/configs/[id]/files                → 403
#   - DELETE /api/skills/configs/[id]/files             → 403
# Admins can still scan built-ins and clone them via the gallery's
# "Clone" action (POST /api/skills/configs/[id]/clone) to produce
# an editable user-owned copy.
#
# Set to `true` to restore the legacy behaviour where any
# authenticated user could edit / delete built-in rows directly.
# Internal seed/import paths (POST /api/skills/seed,
# /api/skills/templates/import) are unaffected by this flag.
# ALLOW_BUILTIN_SKILL_MUTATION=false

# ===========================================
# Skills Builder — AI generate / enhance (dynamic-agents)
# ===========================================
#
# Server-side only: Next.js API routes call dynamic-agents POST /api/v1/assistant/suggest.
# Must match the host:port where dynamic-agents actually listens (ECONNREFUSED = wrong URL or service down).
# Default if unset: http://localhost:8100
#
# DYNAMIC_AGENTS_URL=http://localhost:8100
#
# Optional model overrides for /api/skills/generate (see route.ts for defaults).
# SKILL_AI_MODEL_ID=bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0
# SKILL_AI_MODEL_PROVIDER=openai

# ===========================================
# Header Link Configuration (Optional)
# ===========================================
#
# Control the documentation and source code links in the header.
# Leave empty/commented to hide these links.

# Documentation URL - shows a book icon linking to docs
# DOCS_URL=https://your-docs-site.com

# Source code URL - shows a GitHub icon linking to source
# SOURCE_URL=https://github.com/your-org/your-repo

# ===========================================
# Theme / Gradient Customization (Optional)
# ===========================================
#
# Customize the primary gradient colors used throughout the UI.
# Colors should be in HSL format: "hsl(hue, saturation%, lightness%)"
# or any valid CSS color value (hex, rgb, etc.)
#

# Gradient start color (default: "hsl(173,80%,40%)" - teal)
NEXT_PUBLIC_GRADIENT_FROM=hsl(173,80%,40%)

# Gradient end color (default: "hsl(270,75%,60%)" - purple)
NEXT_PUBLIC_GRADIENT_TO=hsl(270,75%,60%)

# Logo style: "default" (original colors) or "white" (inverted to white)
# Use "white" when your logo needs to appear on gradient backgrounds
# Use "default" when your logo already has the right colors for the background
NEXT_PUBLIC_LOGO_STYLE=default

# Spinner/loading indicator color (default: uses primary theme color)
# Can be any valid CSS color (hex, hsl, rgb, etc.)
# NEXT_PUBLIC_SPINNER_COLOR=#00bcd4

# Show "Powered by OSS caipe.io" footer (default: true)
# Set to "false" to hide the footer on login, logout, and loading screens
NEXT_PUBLIC_SHOW_POWERED_BY=true

# ===========================================
# Langfuse User Feedback Configuration (Optional)
# ===========================================
#
# Langfuse is used for tracking user feedback on AI responses.
# When configured, thumbs up/down feedback is sent to Langfuse
# as scores linked to traces for quality analysis.
#
# The feedback is sent server-side to keep the secret key secure.
#
# See: https://langfuse.com/docs/observability/features/user-feedback
#

# Langfuse public key (required for feedback tracking)
# Get this from your Langfuse project settings
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx

# Langfuse secret key (required for feedback tracking, server-side only)
# Get this from your Langfuse project settings
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# Langfuse host URL (required for feedback tracking)
# For cloud: https://cloud.langfuse.com
# For self-hosted: http://langfuse-web:3000 or your custom URL
# LANGFUSE_HOST=https://cloud.langfuse.com

# ===========================================
# Skills middleware / skill-scanner (operator reference)
# ===========================================
#
# Max skill summaries injected into the agent system prompt.
# 0 or unset = no cap (all merged skills). FR-024.
# MAX_SKILL_SUMMARIES_IN_PROMPT=100
#
# JWT claim holding team / group ids for catalog entitlement (FR-020). Python router.
# OIDC_TEAMS_CLAIM=groups
#
# Catalog API key auth: header name and HMAC pepper for stored key hashes (BFF + Python).
# CAIPE_CATALOG_API_KEY_HEADER=X-Caipe-Catalog-Key
# CAIPE_CATALOG_API_KEY_PEPPER=<openssl rand -hex 32>
#
# MongoDB collection catalog_api_keys: key_id, key_hash, owner_user_id, scopes, revoked_at
# Mint/list/revoke via GET|POST|DELETE /api/catalog-api-keys.
#
# Skills catalog: local BFF merge (Mongo + hubs + templates).
#
# Packaged skills scan (scripts/scan-packaged-skills.sh): directory of SKILL.md trees.
# SKILLS_DIR=/path/to/bundled/skills
#
# Scanner gate: strict (default) excludes flagged + unscanned skills from the
# agent skills catalog and dynamic agents; warn surfaces warnings but only blocks
# explicitly flagged skills; off disables severity-based gating entirely.
# Note: scan_status="flagged" is ALWAYS blocked regardless of this setting.
# SKILL_SCANNER_GATE=strict
# SKILL_SCANNER_POLICY=balanced
# SKILL_SCANNER_FAIL_ON=high
#
# URL of the standalone cisco-ai-defense/skill-scanner API server. The UI
# uploads zipped SKILL packages here for safety scanning. Bring it up via:
#   docker compose --profile skill-scanner up -d
# (or `--profile caipe-ui`, which transitively starts the scanner).
# Helm: enable `global.skillScanner.enabled=true` in the parent chart.
SKILL_SCANNER_URL=http://localhost:8765

# ===========================================

# ===========================================
# Audit Log Storage Backend
# ===========================================
# UI emits audit events to audit-service. audit-service owns local/S3 storage.
# AUDIT_LOG_BACKEND=service
# AUDIT_SERVICE_URL=http://audit-service:8010
